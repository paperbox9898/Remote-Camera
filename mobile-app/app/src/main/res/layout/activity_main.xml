<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Human Guard"
                    android:textColor="#F8FAFC"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSettingsSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="설정을 확인하세요"
                    android:textColor="#CBD5E1"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="92dp"
                android:layout_height="44dp"
                android:text="설정"
                android:textSize="14sp"
                android:textColor="#F8FAFC"
                android:backgroundTint="#334155" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginBottom="14dp"
            android:background="#020617">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#020617"
                app:scaleType="fitCenter" />

            <com.remotecamera.app.DetectionOverlayView
                android:id="@+id/overlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnLive"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="실시간 시작"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB" />

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="이미지 판정"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#475569" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btnClearArea"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="영역 초기화"
                android:textSize="13sp"
                android:textColor="#E2E8F0"
                android:backgroundTint="#334155" />

            <Button
                android:id="@+id/btnUploadReference"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="검사 기준"
                android:textSize="13sp"
                android:textColor="#E2E8F0"
                android:backgroundTint="#334155" />

            <Button
                android:id="@+id/btnResults"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="결과"
                android:textSize="13sp"
                android:textColor="#E2E8F0"
                android:backgroundTint="#334155" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="대기 중"
            android:textColor="#F8FAFC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="프리뷰를 터치해 감시 영역을 지정하세요"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="10dp" />

        <ImageView
            android:id="@+id/ivResultImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:adjustViewBounds="true"
            android:background="#1E293B"
            android:contentDescription="판정 결과 이미지"
            android:scaleType="fitCenter" />

    </LinearLayout>

</ScrollView>
