<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="결과 리스트"
            android:textColor="#F9FAFB"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvHistoryStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서버 이력을 불러옵니다"
            android:textColor="#D1D5DB"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnRefreshHistory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="새로고침"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#2563EB"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvSelectedImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D1D5DB"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivSelectedResult"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            android:adjustViewBounds="true"
            android:background="#1F2937"
            android:contentDescription="선택한 결과 이미지"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/llHistoryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
